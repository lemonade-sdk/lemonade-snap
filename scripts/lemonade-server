#!/bin/bash

# lemonade-server - Check status of lemonade server

# Read server URL from snap settings
URL=$(snapctl get server-url)
URL=${URL:-http://127.0.0.1:8000}

status() {
    # Try to get status from the server
    response=$(curl -s --connect-timeout 2 "${URL}/health" 2>/dev/null)

    if [ $? -eq 0 ] && [ -n "$response" ]; then
        echo "Server is running at ${URL}"
        exit 0
    else
        echo "Server is not running"
        exit 1
    fi
}

case "$1" in
    status)
        status
        ;;
    *)
        echo "Usage: lemonade-server {status}"
        exit 1
        ;;
esac
